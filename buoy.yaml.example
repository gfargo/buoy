# ┌──────────────────────────────────────────────────────────┐
# │  buoy.yaml — configuration for the Buoy dashboard       │
# │                                                          │
# │  Minimal config: just set node.name and you're running.  │
# │  Everything else has sensible defaults.                  │
# │                                                          │
# │  Environment variables override any value here.          │
# │  Prefix: BUOY_ (e.g., BUOY_NODE_NAME, BUOY_AUTH_TOKEN)  │
# └──────────────────────────────────────────────────────────┘

# ── Node Identity ──────────────────────────────────────────
# The name shown in the dashboard header and used for fleet identification.
node:
  name: my-server            # Required: your hostname or display name
  tier: ""                   # Optional: label like "Tier 1A", "prod", "edge"
  role: ""                   # Optional: description like "Database Server"

# ── Network ────────────────────────────────────────────────
network:
  listen_port: 8090          # Port buoy listens on

  # If set, enables Tailscale-aware URL generation (HTTPS links via tailnet)
  tailnet_domain: ""         # e.g., "tailb82ead.ts.net"

  # Fleet peers — other buoy instances to show in the Network section.
  # Each peer's /api/stats is polled for live vitals.
  peers: []
  # Example:
  # peers:
  #   - name: harbor
  #     url: https://harbor.example.ts.net
  #     tier: "Tier 1A"
  #   - name: watch
  #     url: https://watch.example.ts.net
  #     tier: "Tier 2"

# ── Services ───────────────────────────────────────────────
# Buoy auto-discovers local Docker containers and shows them as services.
# Use 'hidden' to exclude noise, 'overrides' to customize display.
services:
  # Container names to hide from the dashboard
  hidden: []
  # Example:
  # hidden:
  #   - "redis"
  #   - "postgres"
  #   - "my-app-db-1"

  # Display overrides for discovered containers
  overrides: {}
  # Example:
  # overrides:
  #   grafana:
  #     name: Grafana
  #     icon: "\U0001F4CA"    # 📊
  #     desc: "Dashboards & Logs"
  #     port: 3000
  #   jellyfin:
  #     name: Jellyfin
  #     icon: "\U0001F3AC"    # 🎬
  #     desc: "Media Server"
  #     port: 8096

# ── Theme ──────────────────────────────────────────────────
theme:
  preset: terminal           # terminal (dark) | light
  # For custom CSS variable overrides:
  # custom:
  #   bg: "#0a0c0f"
  #   surface: "#12151a"
  #   accent: "#e8a838"

# ── Authentication ─────────────────────────────────────────
# Optional. When enabled, protects destructive APIs (restart, logs).
# Read-only APIs (stats, services) remain public for fleet polling.
auth:
  enabled: false
  type: token                # token | basic
  token: ""                  # Set via BUOY_AUTH_TOKEN env var (preferred)
  # For basic auth:
  # username: admin
  # password: ""             # Set via BUOY_AUTH_PASSWORD env var

# ── Features ───────────────────────────────────────────────
features:
  websocket: true            # Real-time updates via WebSocket
  history: false             # SQLite ring buffer for 24h trends (Phase 5)
  demo_mode: false           # Serve mock data (no Docker/host access needed)
  night_mode: auto           # auto (10pm-6am) | always | never
  keyboard_shortcuts: true   # 1-4 for gauges, Escape to close
  image_updates: false       # Docker image update checker (badges on container cards)

# ── Refresh Intervals (seconds) ───────────────────────────
refresh:
  stats_interval: 5          # System vitals polling
  services_interval: 30      # Service discovery refresh
  fleet_interval: 15         # Peer node polling
  plugins_interval: 60       # Plugin data refresh
  image_updates_interval: 21600  # Image update check interval (6 hours)

# ── Plugins ────────────────────────────────────────────────
# Built-in plugins are disabled by default. Enable and configure below.
# Custom plugins go in the /plugins volume mount.
#
# Plugin secrets can be supplied via environment variables so YAML files can be
# committed with empty secret fields. Convention: BUOY_PLUGIN_<ID>_<KEY>
# (uppercased, underscores preserved). Examples:
#   BUOY_PLUGIN_PLANE_API_KEY        → plugins.builtin.plane.api_key
#   BUOY_PLUGIN_GITHUB_TOKEN         → plugins.builtin.github.token
#   BUOY_PLUGIN_TRIGGER_DEV_API_KEY  → plugins.builtin.trigger_dev.api_key
#   BUOY_PLUGIN_PROXMOX_TOKEN_SECRET → plugins.builtin.proxmox.token_secret
# Env present always wins over the YAML value.
plugins:
  enabled: true
  directory: /plugins        # Mount point for user plugins

  builtin:
    # GitHub notifications + open PRs
    github:
      enabled: false
      token: ""              # Or BUOY_PLUGIN_GITHUB_TOKEN (or legacy BUOY_GITHUB_TOKEN)

    # UptimeKuma service health badges
    uptime_kuma:
      enabled: false
      url: ""                # e.g., http://localhost:3001

    # Loki recent error log
    loki:
      enabled: false
      url: ""                # e.g., http://localhost:3100

    # Plane sprint/cycle progress
    plane:
      enabled: false
      api_key: ""            # Or BUOY_PLUGIN_PLANE_API_KEY env var
      url: ""
      workspace: ""
      project: ""

    # Actual Budget monthly summary (pending)
    actual_budget:
      enabled: false
      url: ""

    # SnapRAID parity status
    snapraid:
      enabled: false
      status_file: /var/snapraid/snapraid.status   # path to saved status file
      sync_max_age_hours: 24                        # warn if last sync older than this

    # Tailscale peer status (direct/relay, online/offline, exit node)
    # No config needed — auto-detects tailscale via nsenter into host.
    # Requires privileged + pid: host container.
    tailscale:
      enabled: false

    # Immich photo library stats
    immich:
      enabled: false
      url: ""              # e.g., http://localhost:2283
      api_key: ""          # Immich API key (admin account required for statistics)

    # Jellyfin media server status (active streams, libraries, transcoding)
    jellyfin:
      enabled: false
      url: ""                # e.g., http://localhost:8096
      api_key: ""            # Jellyfin API key (Dashboard → API Keys)

    # Proxmox VE node + guest status
    # Note: verify_ssl defaults to false — PVE uses self-signed certs by default
    proxmox:
      enabled: false
      url: "https://proxmox.example.com:8006"
      token_id: "user@pam!tokenid"   # PVE API token ID (user@realm!tokenid)
      token_secret: ""               # PVE API token secret
      node: "pve"                    # Node name (shown in PVE UI)
      verify_ssl: false

    # WireGuard peer handshake freshness + transfer stats
    # For non-Tailscale setups (raw WireGuard, Firezone, etc.)
    # Requires: privileged + pid: host deployment (see README)
    wireguard:
      enabled: false
      interface: wg0          # WireGuard interface name
      stale_seconds: 180      # Seconds before a peer handshake is considered stale

    # Portainer remote container stats
    portainer:
      enabled: false
      url: ""                # e.g., https://portainer.example.com
      api_key: ""            # Or BUOY_PLUGIN_PORTAINER_API_KEY env var
      endpoint_id: 1         # Portainer endpoint/environment ID
      verify_ssl: true       # Set false for self-signed certs (insecure)

    # Pi-hole / AdGuard Home DNS filtering stats
    # type: pihole  → queries {url}/admin/api.php?summaryRaw (Pi-hole v5, no auth for summary)
    # type: adguard → queries {url}/control/stats with HTTP Basic auth
    dns_filter:
      enabled: false
      type: pihole             # pihole | adguard
      url: ""                  # e.g., http://192.168.1.1 or http://adguard:3000
      api_key: ""              # Pi-hole: API token for top-domains (optional)
                               # AdGuard: "username:password" for Basic auth (optional)
      username: ""             # AdGuard: Basic-auth username (alternative to api_key)
      password: ""             # AdGuard: Basic-auth password
      verify_ssl: true         # Set false for self-signed certs (insecure)

    # Trigger.dev task run status (recent runs, 24h failures, queue depth)
    trigger_dev:
      enabled: false
      url: "https://api.trigger.dev"   # or your self-hosted Trigger.dev URL
      api_key: ""                      # Secret key (tr_prod_…, tr_dev_…)
      project_ref: ""                  # Project reference (e.g. "proj_abc123")
      queue_warn_threshold: 50         # Queued+executing runs before status → error

    # SMART disk health (SATA + NVMe) — requires privileged + pid: host
    smart_disk:
      enabled: false
      drives: []   # empty = auto-detect via smartctl --scan
